<?xml version="1.0" encoding="utf-8"?>
<!--
    Excludes all app data from both cloud backup and device-to-device transfer.
    This file is referenced by android:dataExtractionRules in the manifest (API 31+).
    Combined with android:allowBackup="false" this ensures zero data leaves the device
    through any Android backup channel.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
