<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Explicitly remove INTERNET. The tools:node="remove" directive ensures
        no library dependency can merge this permission back in.
    -->
    <uses-permission
        android:name="android.permission.INTERNET"
        tools:node="remove" />

    <!-- Required for the OS to bind to our NotificationListenerService -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE" />

    <!-- Runtime permission for Tier 1 contact whitelist sync (background ContactsContract read) -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Required to post notifications on API 33+. Granted at runtime in the onboarding Activity. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        Declare visibility to all apps that expose a launcher intent.
        Required on API 30+ — without this, PackageManager silently omits
        third-party apps (YouTube, WhatsApp, etc.) from query results.
        This does NOT grant any new capabilities; it only makes those packages
        visible to our PackageManager calls. No QUERY_ALL_PACKAGES permission needed.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".ZigApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ZiG"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            The service must be exported so the OS can bind to it.
            The BIND_NOTIFICATION_LISTENER_SERVICE permission restricts who
            can bind — only the system is allowed.
        -->
        <service
            android:name=".service.ZigNotificationListenerService"
            android:exported="true"
            android:label="@string/service_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>

</manifest>
