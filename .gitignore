# Android build outputs
build/
app/build/
app/release/
*.apk
*.aab
*.ap_

# Android local configuration — machine-specific, never commit
local.properties

# Gradle caches and daemon state
.gradle/

# IDE project files
.idea/

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
# Gradle wrapper JAR must be committed — it bootstraps the build on fresh clones
!gradle/wrapper/gradle-wrapper.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Kotlin Gradle plugin data, see https://kotlinlang.org/docs/whatsnew20.html#new-directory-for-kotlin-data-in-gradle-projects
.kotlin/

# Rust build cache — regenerated by cargo on every build
native/rust_filter/target/

# Compiled JNI .so files — regenerated by the buildRustLib Gradle task
app/src/main/jniLibs/

# macOS metadata — never commit
.DS_Store

# On-device ML model binaries — too large for git, must be sideloaded onto the device
*.task